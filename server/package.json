{
  "name": "mooday-server",
  "version": "1.0.0",
  "description": "Mooday API server",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "build": "npx prisma generate && cd ../client && npm install --include=dev && npm run build"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.5",
    "cookie-parser": "^1.4.6",
    "prisma": "^5.19.0",
    "@prisma/client": "^5.19.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "express-rate-limit": "^7.4.0",
    "socket.io": "^4.7.5",
    "bull": "^4.16.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
